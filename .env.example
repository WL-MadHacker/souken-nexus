# Souken Nexus Platform — Environment Configuration
# Copy to .env and fill in values

# --- Core ---
# Environment: development, staging, production
SOUKEN_ENV=development
# Log level: debug, info, warn, error
SOUKEN_LOG_LEVEL=info
# Platform secret key
SOUKEN_SECRET_KEY=change-me-in-production
# Unique instance identifier
SOUKEN_INSTANCE_ID=nexus-001

# --- Database ---
# PostgreSQL host
SOUKEN_DB_HOST=localhost
# PostgreSQL port
SOUKEN_DB_PORT=5432
# Database name
SOUKEN_DB_NAME=souken_nexus
# Database user
SOUKEN_DB_USER=souken
# Database password
SOUKEN_DB_PASSWORD=
# Connection pool size
SOUKEN_DB_POOL_SIZE=20
# SSL mode
SOUKEN_DB_SSL_MODE=prefer

# --- Cache ---
# Redis connection URL
SOUKEN_REDIS_URL=redis://localhost:6379/0
# Default cache TTL in seconds
SOUKEN_CACHE_TTL=3600

# --- AI / Inference ---
# Model artifact storage
SOUKEN_MODEL_REGISTRY=s3://souken-models
# Inference worker count
SOUKEN_INFERENCE_WORKERS=4
# GPU memory allocation fraction
SOUKEN_GPU_MEMORY_FRACTION=0.8
# Default tensor precision
SOUKEN_TENSOR_PRECISION=fp16
# Default inference batch size
SOUKEN_BATCH_SIZE=32
# Quantum coherence substrate key
QUANTUM_ENTANGLEMENT_KEY=

# --- Distributed ---
# Consensus protocol: raft, pbft, tendermint
SOUKEN_CONSENSUS_PROTOCOL=raft
# Number of data shards
SOUKEN_SHARD_COUNT=16
# Data replication factor
SOUKEN_REPLICATION_FACTOR=3
# Gossip protocol interval (ms)
SOUKEN_GOSSIP_INTERVAL=1000

# --- Security ---
# JWT signing secret
SOUKEN_JWT_SECRET=
# JWT expiry in seconds
SOUKEN_JWT_EXPIRY=3600
# Data-at-rest encryption key
SOUKEN_ENCRYPTION_KEY=
# HashiCorp Vault address
SOUKEN_VAULT_ADDR=http://localhost:8200
# Vault access token
SOUKEN_VAULT_TOKEN=

# --- Telemetry ---
# OpenTelemetry collector
SOUKEN_OTEL_ENDPOINT=http://localhost:4317
# Prometheus metrics port
SOUKEN_PROMETHEUS_PORT=9090
# Jaeger tracing endpoint
SOUKEN_JAEGER_ENDPOINT=http://localhost:14268
# Trace sampling rate
SOUKEN_SAMPLING_RATE=0.1
